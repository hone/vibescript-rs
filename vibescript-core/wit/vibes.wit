package xipkit:vibes;

interface engine-world {
    variant value {
        i(s64),
        f(f64),
        s(string),
        b(bool),
        json(string),
        none
    }

    record named-value {
        name: string,
        val: value,
    }

    record engine-config {
        max-steps: u64,
        max-memory-bytes: u64,
    }

    resource script {
        call: func(func-name: string, args: list<value>, kwargs: list<named-value>) -> result<value, string>;
    }

    resource engine {
        constructor(cfg: engine-config);
        compile: func(source: string) -> result<script, string>;
    }
}

world vibes-provider {
    export engine-world;
}
